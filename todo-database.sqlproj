<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <DSP>Microsoft.Data.Tools.Schema.Sql.Sql110DatabaseSchemaProvider</DSP>
    <ProjectGuid>{B1A1A1A1-A1A1-A1A1-A1A1-B1A1A1A1A1A1}</ProjectGuid>
    <Name>todo-database</Name>
    <RootNamespace>todo_database</RootNamespace>
    <ModelCollation>1033, CI</ModelCollation>
    <TargetFrameworkVersion>v4.7.2</TargetFrameworkVersion>
    <SqlTargetPlatform>AzureSqlDatabase</SqlTargetPlatform>
    <SuppressWarnings>71501</SuppressWarnings>
  </PropertyGroup>
  <ItemGroup>
    <Folder Include="Tables" />
    <Folder Include="Views" />
    <Folder Include="StoredProcedures" />
    <Build Include="Tables\TodoItem.sql" />
    <Build Include="Tables\managed_identity.sql" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath)\Microsoft\VisualStudio\v$(VisualStudioVersion)\SSDT\Microsoft.Data.Tools.Schema.SqlTasks.targets" Condition="Exists('$(MSBuildExtensionsPath)\Microsoft\VisualStudio\v$(VisualStudioVersion)\SSDT\Microsoft.Data.Tools.Schema.SqlTasks.targets')" />
</Project>